xml: dialogue.

dialogue: (line | narration | -newLine)+.
-newLine: #d?, #a.
-tab: [#9].

line: name, " ", speech, -newLine.
narration: text, -newLine.
text: ["A"-"z"]+, [" " | "." | "," | "!" | "?"]+.
name: ["A"-"z" | " " | "."]+, ":".
speech: (["A"-"z"] | " " | #27 | "," | "!" | "-" | "*" | "." | "?" | "—" | ":" | '"')+, ["!" | "." | "?"]*.

